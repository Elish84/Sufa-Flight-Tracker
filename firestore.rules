rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== פונקציות עזר =====
    function signedIn() {
      return request.auth != null;
    }

    function isDivision() {
      return signedIn() && request.auth.token.email == 'shomron@gmail.com';
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isManager() {
      return signedIn() &&
        exists(/databases/$(database)/documents/manager/$(request.auth.uid));
    }

    function isDeveloper() {
      return signedIn() &&
        exists(/databases/$(database)/documents/developers/$(request.auth.uid));
    }

    // פונקציה לבדיקה האם המשתמש משויך לתעסוקה ספציפית
    function isAssignedTo(depId) {
      return isAdmin() && 
        get(/databases/$(database)/documents/deploymentsMap/$(request.auth.token.email.lower())).data.deployment == depId;
    }

    // =====================================================
    // ============ PROJECT: DEPLOYMENTS (V5) ==============
    // =====================================================
    
    // חוק הליבה: הפרדה מוחלטת לפי תעסוקה
    match /deployments/{depId}/reviews/{docId} {
      allow create: if isAdmin();
      allow read: if isDivision() || isAssignedTo(depId);
      allow update, delete: if isAdmin() && isAssignedTo(depId);
    }

    // תמיכה בשליפה רוחבית (חטיבה / AI)
    match /{path=**}/reviews/{docId} {
      allow read: if isDivision() || isAdmin();
    }

    // =====================================================
    // ============ PROJECT: SECTOR EVENTS =================
    // =====================================================
    match /sectorEvents/{docId} {
      allow create: if true;
      allow read: if signedIn();
      allow update, delete: if isAdmin() || isManager();
    }

    match /roles/{docId} {
      allow read: if true;
      allow create, update, delete: if isManager();
    }

    match /eventTypes/{docId} {
      allow read: if true;
      allow create, update, delete: if isManager();
    }

    // =====================================================
    // ================= PROJECT: REVIEWS ==================
    // =====================================================
    match /reviews/{docId} {
      allow create: if signedIn();
      allow read: if isAdmin() || isDivision();
      allow update, delete: if isAdmin();
    }

    // =====================================================
    // ============== PROJECT: HOUSE SCANS =================
    // =====================================================
    match /houseScans/{docId} {
      allow create: if true;
      allow read: if isAdmin() || isDivision();
      allow update, delete: if isAdmin();
    }

    // =====================================================
    // =================== MAP PINS ========================
    // =====================================================
    match /mapPins/{docId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // =====================================================
    // =================== PLACES ==========================
    // =====================================================
    match /places/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // =====================================================
    // =================== SECTORS =========================
    // =====================================================
    match /sectors/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || isManager();
    }

    // =====================================================
    // ================= TZAMM CALENDAR ====================
    // =====================================================
    match /tzammCalendar/{docId} {
      allow read: if true;
      allow create, update: if true;
    }

    // =====================================================
    // =================== ADMINS ==========================
    // =====================================================
    match /admins/{uid} {
      allow create: if signedIn() && request.auth.uid == uid;
      allow read: if signedIn() && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    match /deploymentsMap/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // =====================================================
    // ================== MANAGER =========================
    // =====================================================
    match /manager/{uid} {
      allow create: if signedIn() && request.auth.uid == uid;
      allow read: if signedIn() && request.auth.uid == uid;
      allow update, delete: if isManager();
    }

    // =====================================================
    // ================= DEVELOPERS =======================
    // =====================================================
    match /developers/{uid} {
      allow create: if signedIn() && request.auth.uid == uid;
      allow read: if signedIn() && request.auth.uid == uid;
      allow update, delete: if isDeveloper();
    }

    // =====================================================
    // =================== SETTINGS ========================
    // =====================================================
    match /settings/{docId} {
      allow read: if true;
      allow create, update, delete: if isDeveloper();
    }

    // =====================================================
    // ============ PROJECT: OBSERVATION OWL ===============
    // =====================================================
    match /formTypes/{docId} {
      allow read: if true; // פתוח לכולם למילוי הטופס
      allow write: if isAdmin();
    }

    match /observationPosts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /frameworks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /observationTrainingReports/{docId} {
      allow create: if true; // פתוח לכולם לשלוח תרגול
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
